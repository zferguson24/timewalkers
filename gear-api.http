### ==========================================
### 7. Create a character
### ==========================================

POST http://localhost:8080/api/characters
Content-Type: application/json

{
  "name": "Jaraxxus",
  "race": "NIGHT_ELF",
  "characterClass": "DEMON_HUNTER"
}

###

# Expects: 409 Conflict — name already taken
POST http://localhost:8080/api/characters
Content-Type: application/json

{
  "name": "jaraxxus",
  "race": "ORC",
  "characterClass": "WARRIOR"
}

###

### ==========================================
### 8. Get a character by name (case-insensitive)
### ==========================================

GET http://localhost:8080/api/characters/Jaraxxus
Accept: application/json

###

GET http://localhost:8080/api/characters/jaraxxus
Accept: application/json

###

# Expects: 404 Not Found
GET http://localhost:8080/api/characters/nonexistent
Accept: application/json

###

### ==========================================
### 9. Equip gear — success cases
### ==========================================

# Equip a full set of leather armor across all armor slots
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "HEAD",      "itemName": "Mask of the Deceiver"},
    {"slot": "SHOULDERS", "itemName": "Thorignir Spaulders"},
    {"slot": "CHEST",     "itemName": "Thorignir Heartguard"},
    {"slot": "WRIST",     "itemName": "Unearthed Bands"},
    {"slot": "HANDS",     "itemName": "Cat Burglar's Grips"},
    {"slot": "WAIST",     "itemName": "Belt of the Silent Path"},
    {"slot": "LEGS",      "itemName": "Thorignir Breeches"},
    {"slot": "FEET",      "itemName": "Feet of the Lynx"}
  ]
}

###

# Equip dual-wield DH weapons (Warglaive main + Fist Weapon off-hand)
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "MAIN_HAND", "itemName": "Warglaives of Devotion"},
    {"slot": "OFF_HAND",  "itemName": "Lefty's Brass Knuckle"}
  ]
}

###

# Partial success — valid item + item not found in DB; equipped list and notFound list both populated
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "HEAD",      "itemName": "Mask of the Deceiver"},
    {"slot": "SHOULDERS", "itemName": "This Item Does Not Exist"}
  ]
}

###

### ==========================================
### 10. Equip gear — rejection cases (400)
### ==========================================

# Expects: 400 — Demon Hunters cannot wear Plate armor
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "HEAD", "itemName": "Mugthol's Helm"}
  ]
}

###

# Expects: 400 — Demon Hunters cannot use Staves
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "MAIN_HAND", "itemName": "Warpcaster's Staff"}
  ]
}

###

# Expects: 400 — Demon Hunters cannot use Shields in off-hand
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "OFF_HAND", "itemName": "Mazthoril Honor Shield"}
  ]
}

###

# Expects: 400 — Cannot request both a 2H main-hand and an off-hand in the same request
# (Applicable to classes that use 2H weapons, e.g. a Warrior equipping a 2H Sword + an off-hand)
# Shown here as a general validation example; Demon Hunters have no 2H weapons.
PATCH http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": [
    {"slot": "MAIN_HAND", "itemName": "Lightforged Blade"},
    {"slot": "OFF_HAND",  "itemName": "Lefty's Brass Knuckle"}
  ]
}

###

### ==========================================
### 11. Unequip specific slots
### ==========================================

# Unequip both weapon slots
DELETE http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": ["MAIN_HAND", "OFF_HAND"]
}

###

# Unequip a single armor slot
DELETE http://localhost:8080/api/characters/Jaraxxus/gear
Content-Type: application/json

{
  "slots": ["HEAD"]
}

###
