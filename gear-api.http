### ==========================================
### 1. Get all armor pieces
### ==========================================

GET http://localhost:8080/api/gear/armor
Accept: application/json

###

### ==========================================
### 2. Get all weapons
### ==========================================

GET http://localhost:8080/api/gear/weapons
Accept: application/json

###

### ==========================================
### 3. Search armor by name (partial match)
### ==========================================

GET http://localhost:8080/api/gear/armor/search?name=mugthol
Accept: application/json

###

GET http://localhost:8080/api/gear/armor/search?name=helm
Accept: application/json

###

GET http://localhost:8080/api/gear/armor/search?name=sentinel
Accept: application/json

###

# Expects: empty array
GET http://localhost:8080/api/gear/armor/search?name=nonexistent
Accept: application/json

###

# Expects: 400 Bad Request
GET http://localhost:8080/api/gear/armor/search
Accept: application/json

###

